---
import type { Memory } from '../data/memories';

interface Props {
  memory: Memory;
  index: number;
}

const { memory, index } = Astro.props;
const dateFormatted = new Date(memory.date).toLocaleDateString('tr-TR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<div class={`memory-card reveal ${index % 2 === 0 ? 'left' : 'right'}`}>
  {memory.image && (
    <div class="memory-image-wrapper">
      <img
        src={memory.image}
        alt={memory.title}
        loading="lazy"
        decoding="async"
        class="memory-image"
      />
    </div>
  )}
  <div class="memory-body">
    <span class="memory-date">{dateFormatted}</span>
    <h3 class="memory-title">{memory.title}</h3>
    <p class="memory-description">{memory.description}</p>
  </div>
</div>

<style>
  .memory-card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(212, 87, 123, 0.06);
    border: 1px solid var(--color-rose-pale);
    max-width: 480px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .memory-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(212, 87, 123, 0.12);
  }

  .memory-image-wrapper {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .memory-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .memory-card:hover .memory-image {
    transform: scale(1.04);
  }

  .memory-body {
    padding: var(--space-sm) var(--space-md) var(--space-md);
  }

  .memory-date {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-surface);
    background: var(--color-rose);
    padding: 2px 12px;
    border-radius: 20px;
    margin-bottom: var(--space-xs);
  }

  .memory-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .memory-description {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
