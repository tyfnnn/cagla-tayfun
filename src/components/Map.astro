---
import { places } from '../data/places';
---

<section class="map-section" id="harita">
  <h2 class="section-title">Birlikte Gezdiğimiz Yerler</h2>

  <div class="map-container reveal">
    <div id="map"></div>
  </div>
</section>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script define:vars={{ places }}>
  async function initMap() {
    const L = await import('leaflet');

    const map = L.map('map', {
      scrollWheelZoom: false,
      attributionControl: true,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    const heartIcon = L.icon({
      iconUrl: '/images/map/marker-heart.svg',
      iconSize: [32, 40],
      iconAnchor: [16, 40],
      popupAnchor: [0, -42],
    });

    const markers = [];

    places.forEach((place) => {
      const marker = L.marker([place.lat, place.lng], { icon: heartIcon }).addTo(map);

      const popupContent = `
        <div style="font-family:'Lora',Georgia,serif;text-align:center;padding:4px 8px;">
          <strong style="font-family:'Playfair Display',Georgia,serif;font-size:1rem;color:#3D2C2C;">${place.name}</strong>
          ${place.note ? `<br><span style="font-size:0.85rem;color:#8C7070;">${place.note}</span>` : ''}
        </div>
      `;

      marker.bindPopup(popupContent, {
        className: 'custom-popup',
        closeButton: false,
        maxWidth: 220,
      });

      markers.push(marker);
    });

    if (markers.length > 0) {
      const group = L.featureGroup(markers);
      map.fitBounds(group.getBounds().pad(0.3));
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>

<style>
  .map-section {
    background: var(--color-bg);
    padding: var(--space-xl) var(--space-md);
  }

  .map-container {
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-rose-pale);
    box-shadow: 0 4px 24px rgba(212, 87, 123, 0.06);
  }

  #map {
    height: 450px;
    width: 100%;
    background: var(--color-bg-alt);
  }

  /* Custom Leaflet popup styling */
  :global(.custom-popup .leaflet-popup-content-wrapper) {
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(61, 44, 44, 0.1);
    border: 1px solid var(--color-rose-pale);
  }

  :global(.custom-popup .leaflet-popup-tip) {
    border-top-color: var(--color-surface);
  }

  @media (max-width: 768px) {
    #map {
      height: 350px;
    }
  }
</style>
