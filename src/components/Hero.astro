---
import FloatingHearts from './FloatingHearts.astro';
---

<section class="hero">
  <FloatingHearts />

  <div class="hero-content">
    <h1 class="hero-names">
      Tayfun <span class="ampersand">&</span> Çağla
    </h1>
    <p class="hero-subtitle">6 Mart 2024'ten beri birlikte...</p>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M7 13l5 5 5-5M7 6l5 5 5-5" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(170deg, var(--color-bg) 0%, var(--color-bg-alt) 40%, var(--color-rose-pale) 100%);
    overflow: hidden;
    text-align: center;
    padding: var(--space-md);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    animation: fadeInUp 1.2s ease-out;
  }

  .hero-names {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .ampersand {
    display: inline-block;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold);
    font-size: 1.15em;
    margin: 0 0.1em;
    animation: pulse 4s ease-in-out infinite;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    font-style: italic;
    animation: fadeIn 1.8s ease-out 0.4s both;
  }

  .scroll-indicator {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    translate: -50% 0;
    color: var(--color-rose-light);
    animation: bounce 2s ease-in-out infinite;
    z-index: 1;
  }

  @media (max-width: 480px) {
    .hero-names {
      font-size: 2.4rem;
    }
  }
</style>
