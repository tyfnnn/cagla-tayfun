---
import { loveLetter } from '../data/love-letter';
---

<section class="letter-section" id="mektup">
  <div class="letter-wrapper reveal">
    <div class="letter-decoration" aria-hidden="true">"</div>

    <h2 class="letter-greeting">{loveLetter.greeting}</h2>

    {loveLetter.paragraphs.map((p) => (
      <p class="letter-paragraph">{p}</p>
    ))}

    <p class="letter-signature">{loveLetter.signature}</p>

    <div class="letter-decoration letter-decoration-end" aria-hidden="true">"</div>
  </div>
</section>

<style>
  .letter-section {
    background: var(--color-bg-alt);
    padding: var(--space-2xl) var(--space-md);
    position: relative;
  }

  .letter-wrapper {
    max-width: 650px;
    margin: 0 auto;
    background: var(--color-surface);
    padding: var(--space-xl) var(--space-lg);
    border-radius: var(--radius-lg);
    box-shadow:
      0 2px 8px rgba(61, 44, 44, 0.04),
      0 12px 40px rgba(212, 87, 123, 0.06);
    border: 1px solid var(--color-rose-pale);
    position: relative;
    overflow: hidden;
  }

  .letter-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-rose-pale), var(--color-gold-light), var(--color-rose-pale));
  }

  .letter-decoration {
    font-family: var(--font-accent);
    font-size: 5rem;
    line-height: 0.6;
    color: var(--color-gold);
    opacity: 0.3;
    user-select: none;
  }

  .letter-decoration-end {
    text-align: right;
    margin-top: var(--space-sm);
  }

  .letter-greeting {
    font-family: var(--font-accent);
    font-size: 1.8rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-rose);
    margin: var(--space-sm) 0 var(--space-md);
  }

  .letter-paragraph {
    font-family: var(--font-accent);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.9;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .letter-signature {
    font-family: var(--font-accent);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin-top: var(--space-md);
    white-space: pre-line;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .letter-wrapper {
      padding: var(--space-lg) var(--space-md);
    }

    .letter-decoration {
      font-size: 3.5rem;
    }
  }
</style>
